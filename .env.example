# Supabase (uNick Teachers Academy project)
NEXT_PUBLIC_SUPABASE_URL=https://ohugscpctjdquebvqigb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key - server only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs - one recurring Price per plan/currency. Created by
# `npm run setup:stripe` (see scripts/setup-stripe.js) or manually in the
# Stripe Dashboard. Amounts must match lib/constants.js PRICES.
STRIPE_PRICE_MONTHLY_USD=
STRIPE_PRICE_MONTHLY_EUR=
STRIPE_PRICE_MONTHLY_PLN=
STRIPE_PRICE_ANNUAL_USD=
STRIPE_PRICE_ANNUAL_EUR=
STRIPE_PRICE_ANNUAL_PLN=

# uNickorn AI Tutor
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# uNickorn Stripe price IDs (per tier)
STRIPE_PRICE_UNICKORN_UNICK_STUDENT=
STRIPE_PRICE_UNICKORN_EXTERNAL=

# uNickorn monthly session limits (defaults: 30 for uNick students, 12 for external)
UNICKORN_MONTHLY_SESSION_LIMIT_UNICK_STUDENT=30
UNICKORN_MONTHLY_SESSION_LIMIT_EXTERNAL=12

# Public site URL, used for Stripe redirect/callback URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
